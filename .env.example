# Discord Bot Configuration
# Get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_discord_application_client_id

# Optional: Guild ID for development (faster command deployment)
GUILD_ID=your_dev_server_id

# 1min.ai API Configuration
# Get your key from https://1min.ai
AI_TOKEN=your_1min_ai_api_key

# Security: Restrict bot to specific guilds (comma-separated, leave empty to allow all)
ALLOWED_GUILD_IDS=

# Rate limiting: max requests per user per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
